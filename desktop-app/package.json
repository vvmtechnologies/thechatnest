{
  "name": "thechatnest-desktop",
  "productName": "TheChatNest",
  "version": "1.0.2",
  "description": "TheChatNest desktop client",
  "main": "main.js",
  "author": {
    "name": "TheChatNest",
    "email": "support@thechatnest.com"
  },
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.thechatnest.desktop",
    "productName": "TheChatNest",
    "files": [
      "main.js",
      "preload.js",
      "downloadManager.js",
      "icons/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TheChatNest"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Network"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "thakurbhavesh",
        "repo": "Dream",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^38.2.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
