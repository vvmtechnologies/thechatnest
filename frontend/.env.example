# TheChatNest — frontend environment variables.
# Copy this file to `.env` and fill in real values.

# ─── Backend (required) ───────────────────────────────────────────────
# Public API base URL. Production is hosted on Render.
VITE_API_URL=https://thechatnest-api.onrender.com
VITE_SERVER_URL=https://thechatnest-api.onrender.com

# ─── Error monitoring (optional) ──────────────────────────────────────
# Paste your Sentry browser DSN here to enable error capture in prod.
# Get one from https://sentry.io → Settings → Projects → [your project]
# → Client Keys (DSN). Leave empty in dev — Sentry stays silent.
VITE_SENTRY_DSN=

# Tag every event with the current release. Override in CI with the git sha.
VITE_APP_VERSION=thechatnest@dev

# ─── Analytics (optional, GDPR-gated) ─────────────────────────────────
# The cookie consent banner only loads these scripts after the user
# accepts the analytics / marketing category, so they stay GDPR-safe
# even if the IDs are public.
# (Hardcoded in index.html right now — move here if you rotate them.)
