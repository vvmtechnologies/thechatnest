# ─── Render + Neon Production Environment Variables ─────
# Set these in Render Dashboard → Environment tab

PORT=5000
NODE_ENV=production

# Neon PostgreSQL (get from neon.tech dashboard)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/thechatnest?sslmode=require
DB_SSL=true

# Redis (optional - set REDIS_ENABLED=false if not using)
REDIS_ENABLED=false

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS (your Vercel frontend URL)
CORS_ORIGIN=https://your-app.vercel.app
FRONTEND_ORIGIN=https://your-app.vercel.app

# Chat Encryption
CHAT_ENCRYPTION_KEY=GENERATE_A_64_CHAR_HEX_STRING

# AWS S3
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=ap-south-1
AWS_S3_BUCKET=thechatnest

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
